# Copy to .env and fill in values

# Telegram bot token (required)
BOT_TOKEN=

# HTTP port the Go server listens on
WEBAPP_PORT=8080

# Path to the shared SQLite database
BOT_DB=bot.db

# Directory for temporary downloaded files
DOWNLOADS_DIR=webapp_dl

# Seconds before a downloaded file is auto-deleted (120 = 2 minutes)
FILE_TTL_SEC=120

# Max file size in MB to serve (0 = no limit, recommended for 300MB+ support)
MAX_FILE_SIZE_MB=0

# Daily download limits
FREE_DL_DAY=3
PREMIUM_DL_DAY=12

# Token salt (keep in sync with Python bot if running side-by-side)
SECRET_SALT=puwe_webapp_v1
